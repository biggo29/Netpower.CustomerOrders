# ============================================================
# Docker Compose environment variables
# Copy this file and adjust values per environment.
# NEVER commit real secrets to source control.
# ============================================================

# SQL Server SA password (must meet SQL Server complexity requirements)
SA_PASSWORD=SqlServer_Docker_2026!

# JWT secret key - MUST be at least 32 characters
JWT_SECRET_KEY=CHANGE_ME_use_a_32plus_char_secret_key_here!